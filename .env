# Application
APP_NAME="Experiment Management API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development
HOST=192.168.1.159
PORT=8000
APP_ENV=development
API_VERSION=v1
API_PREFIX=/api

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=experiments_db
EXPERIMENTS_DB=experiments_db
USERS_DB=users_db
KNOWLEDGE_DB=knowledge_db
READONLY_DB_PASSWORD=Akrawerkatya
# Database URLs (for local development)
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5432/experiments_db
USERS_DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5433/users_db
KNOWLEDGE_DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5434/knowledge_db

# Database Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
REDIS_DEFAULT_TIMEOUT=3600

# Security
SECRET_KEY=lx0JFxVH_B1CYiCLeCJ32dXX8l1V0rW2gZ5IRiukOSk
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_MAX_AGE=86400

# Default Admin User (created on startup if not exists)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Akrawer1

# Metrics endpoint credentials (B15: /metrics is fail-closed in every env)
# Prometheus scrapes /metrics with these via basic_auth (see prometheus.yml).
METRICS_USERNAME=prometheus
METRICS_PASSWORD=metrics-scraper-secret

# CORS Settings
CORS_ORIGINS=["http://192.168.1.217","http://85.142.173.191","http://localhost","http://127.0.0.1"]
CORS_CREDENTIALS=true
CORS_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS", "PATCH"]
CORS_HEADERS=["*"]

# File Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=["image/jpeg", "image/png", "image/webp"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"